# Memory API - LLM Provider
# Choose provider: 'anthropic' or 'deepseek'
MEMORY_LLM_PROVIDER=anthropic
# MEMORY_LLM_PROVIDER=deepseek

# API Keys (use your provider's key)
ANTHROPIC_API_KEY=placeholder-key-not-configured
# For Deepseek: use your Deepseek API key instead
# DEEPSEEK_API_KEY=sk-your-deepseek-key

# Embedding Configuration
# -------------------------------------------
# For Anthropic provider (default):
#   Embeddings use the local SentenceTransformer model ("all-MiniLM-L6-v2").
#   No API key or base URL needed.
#
# For Deepseek provider:
#   Uncomment and set DEEPSEEK_API_KEY above, then embeddings will
#   automatically use https://api.deepseek.com/v1/embeddings.
#
# To use a custom embedding provider (OpenAI, Together, etc.):
#   MEMORY_EMBEDDING_API_BASE=https://api.openai.com/v1
#   MEMORY_EMBEDDING_API_KEY=sk-your-key
#   MEMORY_EMBEDDING_API_MODEL=text-embedding-3-large

# Letta (MemGPT) - Procedural memory tier
LETTA_BASE_URL=http://localhost:8283
LETTA_API_KEY=letta-local-dev-key
